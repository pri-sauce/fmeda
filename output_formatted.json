                    },
                    {
                        "B":  23,
                        "C":  "SM23",
                        "E":  "TEMP",
                        "F":  "ADC: Thermal Monitoring",
                        "G":  "Die temperature measured and stored in DIETEMP register.",
                        "H":  "check status registers for fails",
                        "I":  "MCU resets IC",
                        "K":  "D.2.1.2, D2.4.4",
                        "L":  0.9
                    },
                    {
                        "B":  24,
                        "C":  "SM24",
                        "E":  "ADC, SW_BANK",
